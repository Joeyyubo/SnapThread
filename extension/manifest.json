{
  "manifest_version": 3,
  "name": "SnapThread",
  "version": "0.2.7",
  "description": "UI review and design walkthroughs: capture elements or regions on any HTTP/HTTPS page, snapshot CSS, queue notes, and post to GitHub PRs and issues.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "notifications",
    "sidePanel"
  ],
  "host_permissions": ["http://*/*", "https://*/*", "<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "SnapThread (side panel)",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "<all_urls>"],
      "js": ["content/picker.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
